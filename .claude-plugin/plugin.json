{
  "name": "elmq",
  "version": "0.1.0",
  "description": "Elm file query and edit tools via elmq MCP server",
  "repository": "https://github.com/caseyWebb/elmq",
  "mcpServers": {
    "elmq": {
      "command": "elmq",
      "args": ["mcp"]
    }
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/session-start.sh",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
